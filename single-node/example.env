# Copy this file to a host-local env file such as:
#   single-node/.env.staging
#   single-node/.env.production
#
# Do not put real secrets in this tracked example file.

# These are indexer internal users. For the stock deployment they are reserved
# users initialized inside the Wazuh indexer.
#
# If you change these passwords, also provision a matching
# config-local/opensearch-security/internal_users.yml before the first compose
# up, or apply the matching OpenSearch Security config to an existing indexer.

INDEXER_USERNAME=admin
INDEXER_PASSWORD=admin

DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=kibanaserver
